# --- Database (Railway PostgreSQL の "Connect" タブにある接続URLを使用) ---
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # 生成: openssl rand -base64 32

# --- Claude (AI解説) ---
ANTHROPIC_API_KEY=""

# --- Stripe (Proプラン 月額980円) 未設定ならAI解説は無料開放になります ---
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""       # 月額980円のPrice ID (price_...)
STRIPE_WEBHOOK_SECRET=""  # Stripe CLI / ダッシュボードのWebhookエンドポイントで発行 (whsec_...)

# --- GitHub (任意。設定するとSearch APIのレート制限が 10/分 → 30/分 に緩和されます) ---
GITHUB_TOKEN=""

# --- 管理者バイパス (任意) ---
# ここに列挙したユーザー名(カンマ区切り)は、Stripeの購読状態に関係なく
# 常にPro扱いになりAI解説が無料で使えます。開発者本人用のバックドアです。
# 例: ADMIN_USERNAMES="yasu,yasu_test"
ADMIN_USERNAMES=""
